# ─── APIShield Environment Variables ──────────────────────────────────────────
#
# SETUP (takes ~2 minutes):
#
# 1. Go to https://upstash.com → sign up free (no credit card needed)
# 2. Click "Create Database" → give it a name → click "Create"
# 3. Click the "REST API" tab
# 4. Copy the values below into your Vercel project:
#    Vercel Dashboard → your project → Settings → Environment Variables
#
# ─────────────────────────────────────────────────────────────────────────────

# Upstash Redis REST URL (looks like: https://xxx.upstash.io)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST Token (starts with: AY...)
UPSTASH_REDIS_REST_TOKEN=

# ─── Once configured, the gateway is live at: ────────────────────────────────
#
#   https://your-domain.vercel.app/api/gateway/{path}?api_key=sk_live_xxx
#
#   Or with header:  X-API-Key: sk_live_xxx
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth (NextAuth) ──────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Add Authorized redirect URIs:
#    http://localhost:3000/api/auth/callback/google      (local)
#    https://your-app.vercel.app/api/auth/callback/google  (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Your Vercel deployment URL (no trailing slash)
NEXTAUTH_URL=https://your-app.vercel.app
